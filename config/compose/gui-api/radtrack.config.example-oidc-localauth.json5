{
  app: {
    publicBaseUrl: "http://localhost:8192",
    wuiBaseUrl: "http://localhost:4096",
    basePath: ""
  },
  database: {
    postgres: {
      host: "postgres",
      port: 5432,
      database: "radtrack",
      user: "radtrack"
    }
  },
  redis: {
    url: "redis://redis:6379"
  },
  logging: {
    sinks: {
      console: {
        enabled: true,
        levels: ["info", "warn", "error"],
        format: "text"
      },
      file: {
        enabled: false,
        levels: ["info", "warn", "error"],
        format: "json",
        path: null
      }
    },
    features: {
      cache: {
        enabled: false,
        level: "debug"
      },
      query: {
        enabled: false,
        level: "debug"
      }
    }
  },
  auth: {
    localEnabled: true,
    oidcEnabled: true,
    headerEnabled: false,
    oidc: {
      issuer: "https://login.example.com/realms/radtrack",
      clientId: "radtrack",
      callbackUrl: "http://localhost:8192/auth/callback",
      scopes: ["openid", "profile", "email"]
    },
    header: {
      trustedCidrs: [],
      usernameHeader: "x-auth-request-user",
      emailHeader: "x-auth-request-email"
    }
  },
  ui: {
    defaultTheme: "dark",
    defaultFont: "ui-mono",
    defaultLanguage: "en-US"
  },
  map: {
    tileUrlTemplate: "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
    attribution: "&copy; OpenStreetMap contributors",
    defaultMetric: "doseRate",
    defaultAggregateShape: "hexagon",
    defaultCellSizeMeters: 250,
    rawPointCap: 5000,
    liveUpdatePollingIntervalSeconds: 15
  },
  aggregation: {
    modeBucketDecimals: 2,
    cacheTtlSeconds: 3600,
    cellCacheRefreshTtlOnRead: false
  }
}
